# Usage data source
USAGE_DATA_DIR=/path/to/usage/history

# Backend model pricing aggregate API (server-only)
MODEL_PRICING_API_BASE_URL=
MODEL_PRICING_API_KEY=

# Legacy pricing sync storage
DATABASE_URL=postgres://user:password@host:5432/database

# OpenRouter pricing API
OPENROUTER_API_KEY=your_openrouter_api_key

# Cron endpoint auth: Authorization: Bearer $CRON_SECRET
CRON_SECRET=replace_with_a_random_secret

# Only allow non-force sync during the first N minutes after the hour
PRICING_SYNC_GRACE_MINUTES=10